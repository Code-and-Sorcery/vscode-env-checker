{
  "name": "vscode-env-checker",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.2",
  "publisher": "CodeandSorcery",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Code-and-Sorcery/vscode-env-checker.git"
  },
  "bugs": {
    "url": "https://github.com/Code-and-Sorcery/vscode-env-checker/issues"
  },
  "homepage": "https://github.com/Code-and-Sorcery/vscode-env-checker#readme",
  "keywords": [
    "env",
    "dotenv",
    "environment",
    "environment variables",
    "config",
    "compare",
    "diff",
    ".env",
    "env example"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:envChecker.editor",
    "onLanguage:dotenv",
    "onCommand:envChecker.openFormattedView",
    "onCommand:envChecker.compareEnvFiles",
    "onCommand:envChecker.compareWithExample",
    "onCommand:envChecker.reopenAsTextEditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "envChecker.editor",
        "displayName": "%view.envChecker.displayName%",
        "selector": [
          {
            "filenamePattern": "**/.env"
          },
          {
            "filenamePattern": "**/.env.*"
          }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "dotenv",
        "aliases": [
          "Dotenv",
          "env"
        ],
        "extensions": [
          ".env",
          ".env.local",
          ".env.development",
          ".env.production",
          ".env.test",
          ".env.example",
          ".env.sample",
          ".env.template",
          ".env.staging",
          ".env.ci",
          ".env.development.local",
          ".env.production.local",
          ".env.test.local"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "envChecker.relatedFileNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env.example",
            ".env.sample",
            ".env.template",
            ".env.test",
            ".env.testing",
            ".env.local",
            ".env.development",
            ".env.production",
            ".env.staging",
            ".env.ci",
            ".env.development.local",
            ".env.production.local",
            ".env.test.local"
          ],
          "description": "%config.relatedFileNames.description%"
        }
      }
    },
    "commands": [
      {
        "command": "envChecker.openFormattedView",
        "title": "%command.openFormattedView.title%"
      },
      {
        "command": "envChecker.compareEnvFiles",
        "title": "%command.compareEnvFiles.title%"
      },
      {
        "command": "envChecker.compareWithExample",
        "title": "%command.compareWithExample.title%"
      },
      {
        "command": "envChecker.reopenAsTextEditor",
        "title": "%command.reopenAsTextEditor.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "envChecker.openFormattedView",
          "when": "resourceScheme == file && resourceFilename =~ /^\\.env(\\.|$)/",
          "group": "navigation@1"
        },
        {
          "command": "envChecker.compareWithExample",
          "when": "resourceScheme == file && resourceFilename =~ /^\\.env(\\.|$)/",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "envChecker.openFormattedView",
          "when": "resourceScheme == file && resourceFilename =~ /^\\.env(\\.|$)/",
          "group": "navigation@1"
        },
        {
          "command": "envChecker.compareWithExample",
          "when": "resourceScheme == file && resourceFilename =~ /^\\.env(\\.|$)/",
          "group": "navigation@2"
        }
      ]
    }
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --sourcemap --legal-comments=none --outfile=out/extension.js --format=cjs",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --sourcemap --legal-comments=none --outfile=out/extension.js --format=cjs --watch=forever",
    "typecheck": "tsc --noEmit -p ./",
    "pack": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "lucide": "^1.7.0",
    "ovsx": "^0.10.10",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3"
  }
}
