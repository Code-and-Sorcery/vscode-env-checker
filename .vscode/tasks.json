{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "pnpm run watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "label": "pnpm: watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "type": "shell",
      "command": "pnpm run compile",
      "problemMatcher": "$tsc",
      "label": "pnpm: compile",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
